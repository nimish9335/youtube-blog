<!DOCTYPE html>
<html lang="en">
<head>
    <%- include ('./partials/head') %>
    <title><%= blog.title %></title>
</head>
<body>
    <%- include ('./partials/nav') %>

    <main class="container py-5">
        <article class="blog-detail mx-auto">
        <% if(blog.coverImage){ %>
            <img src="<%= blog.coverImage %>" class="blog-hero-img mb-4" alt="<%= blog.title %> cover image">
        <% } %>

        <h1 class="fw-bold mb-3"><%= blog.title %></h1>

        <% if(blog.author){ %>
            <p class="text-muted">By <%= blog.author.name %></p>
        <% } %>

        <p class="blog-content"><%= blog.content %></p>
        </article>
    </main>

    <%- include ('./partials/scripts') %>
</body>
</html>

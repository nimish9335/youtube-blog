<!DOCTYPE html>
<html lang="en">
<head>
    <%- include ('./partials/head') %>
    <title>Home Page</title>
</head>
<body>
    <%- include ('./partials/nav') %>

    <main class="container py-5">
        <div class="page-header mb-4">
            <p class="text-uppercase text-primary fw-semibold mb-2">Fresh stories</p>
            <h1 class="fw-bold mb-2">Explore latest blogs</h1>
            <p class="text-muted mb-0">Read ideas, notes, and stories shared by the community.</p>
            <% if(typeof user === 'undefined' || !user){ %>
                <div class="d-flex flex-wrap gap-2 mt-3">
                    <a href="/user/signup" class="btn btn-primary">Create account</a>
                    <a href="/user/signin" class="btn btn-outline-primary">Login</a>
                </div>
            <% } else { %>
                <a href="/blog/addblog" class="btn btn-primary mt-3">Add blog</a>
            <% } %>
        </div>

        <% if(blogs && blogs.length){ %>
            <div class="row g-4">
                <% blogs.forEach((blog)=>{ %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card blog-card h-100">
                            <% if(blog.coverImage){ %>
                                <img src="<%= blog.coverImage %>" class="card-img-top blog-card-img" alt="<%= blog.title %> cover image">
                            <% } else { %>
                                <div class="blog-card-img blog-card-placeholder">Blogify</div>
                            <% } %>
                            <div class="card-body d-flex flex-column">
                                <p class="text-muted small mb-2">
                                    <%= blog.author ? blog.author.name : 'Unknown author' %>
                                </p>
                                <h5 class="card-title"><%= blog.title %></h5>
                                <p class="card-text text-muted"><%= blog.content.length > 120 ? blog.content.slice(0,120) + '...' : blog.content %></p>
                                <a href="/blog/<%= blog.id %>" class="btn btn-primary mt-auto">Read more</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <h2>No blogs yet</h2>
                <p class="text-muted mb-3">Once you add a blog, it will appear here.</p>
                <% if(typeof user !== 'undefined' && user){ %>
                    <a href="/blog/addblog" class="btn btn-primary">Add blog</a>
                <% } else { %>
                    <a href="/user/signup" class="btn btn-primary">Create account</a>
                    <a href="/user/signin" class="btn btn-outline-primary ms-2">Login</a>
                <% } %>
            </div>
        <% } %>
    </main>

    <%- include ('./partials/scripts') %>
</body>
</html>

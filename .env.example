PORT=8000
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/youtube_blog
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
NODE_ENV=development

# CORS Configuration (for AWS deployment)
CORS_ORIGIN=https://yourdomain.com

# AWS S3 Configuration (Optional - for image uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
